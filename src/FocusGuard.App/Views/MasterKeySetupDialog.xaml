<Window x:Class="FocusGuard.App.Views.MasterKeySetupDialog"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        Title="FocusGuard — Master Key Setup" Width="500" Height="400"
        WindowStartupLocation="CenterScreen" ResizeMode="NoResize"
        WindowStyle="None" AllowsTransparency="True" Background="Transparent">
    <Border Background="{StaticResource BackgroundBrush}" CornerRadius="12"
            BorderBrush="{StaticResource BorderBrush}" BorderThickness="1">
        <Grid Margin="28">
            <Grid.RowDefinitions>
                <RowDefinition Height="Auto" />
                <RowDefinition Height="*" />
                <RowDefinition Height="Auto" />
            </Grid.RowDefinitions>

            <!-- Header -->
            <StackPanel Grid.Row="0" Margin="0,0,0,16">
                <TextBlock Text="Master Recovery Key" Style="{StaticResource HeadingStyle}" Margin="0" />
                <TextBlock TextWrapping="Wrap" Foreground="{StaticResource TextSecondaryBrush}" FontSize="13"
                           Margin="0,8,0,0"
                           Text="FocusGuard generates a master recovery key for emergency unlocks. Save this key somewhere safe — it will only be shown once." />
            </StackPanel>

            <!-- Content -->
            <StackPanel Grid.Row="1" VerticalAlignment="Center">
                <!-- Master Key Display -->
                <Border Background="{StaticResource SurfaceLightBrush}" CornerRadius="8"
                        Padding="16" Margin="0,0,0,12">
                    <TextBlock Text="{Binding MasterKey}" FontFamily="Consolas" FontSize="18"
                               FontWeight="Bold" Foreground="{StaticResource PrimaryBrush}"
                               TextWrapping="Wrap" TextAlignment="Center" />
                </Border>

                <!-- Copy Button -->
                <Button HorizontalAlignment="Center" Margin="0,0,0,16" Cursor="Hand"
                        Command="{Binding CopyToClipboardCommand}">
                    <Button.Style>
                        <Style TargetType="Button" BasedOn="{StaticResource SecondaryButtonStyle}">
                            <Setter Property="Content" Value="Copy to Clipboard" />
                            <Style.Triggers>
                                <DataTrigger Binding="{Binding IsCopied}" Value="True">
                                    <Setter Property="Content" Value="Copied!" />
                                </DataTrigger>
                            </Style.Triggers>
                        </Style>
                    </Button.Style>
                </Button>

                <!-- Confirmation Checkbox -->
                <CheckBox IsChecked="{Binding HasSavedKey}" Margin="0,0,0,0" Cursor="Hand">
                    <TextBlock Text="I have saved this key in a safe place"
                               Foreground="{StaticResource TextBrush}" FontSize="13" />
                </CheckBox>
            </StackPanel>

            <!-- Continue Button -->
            <Button Grid.Row="2" Content="Continue" Style="{StaticResource PrimaryButtonStyle}"
                    HorizontalAlignment="Right" Width="120"
                    IsEnabled="{Binding HasSavedKey}"
                    Command="{Binding ContinueCommand}"
                    CommandParameter="{Binding RelativeSource={RelativeSource AncestorType=Window}}" />
        </Grid>
    </Border>
</Window>
