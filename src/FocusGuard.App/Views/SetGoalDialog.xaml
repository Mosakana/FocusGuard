<Window x:Class="FocusGuard.App.Views.SetGoalDialog"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        Title="Set Focus Goal"
        Width="440" Height="400"
        WindowStyle="None" AllowsTransparency="True"
        WindowStartupLocation="CenterOwner" ResizeMode="NoResize"
        Background="Transparent">
    <Border Background="{StaticResource BackgroundBrush}" CornerRadius="12" BorderBrush="{StaticResource BorderBrush}" BorderThickness="1">
        <Grid Margin="24">
            <Grid.RowDefinitions>
                <RowDefinition Height="Auto" />
                <RowDefinition Height="*" />
                <RowDefinition Height="Auto" />
            </Grid.RowDefinitions>

            <!-- Header -->
            <StackPanel Grid.Row="0" Margin="0,0,0,20">
                <TextBlock Text="Set Focus Goal" FontSize="20" FontWeight="Bold"
                           Foreground="{StaticResource TextBrush}" />
                <TextBlock Text="Set a daily or weekly focus target"
                           Foreground="{StaticResource TextSecondaryBrush}" FontSize="13" Margin="0,4,0,0" />
            </StackPanel>

            <!-- Content -->
            <StackPanel Grid.Row="1">
                <!-- Period Selection -->
                <TextBlock Text="Goal Period" FontSize="13" FontWeight="SemiBold"
                           Foreground="{StaticResource TextBrush}" Margin="0,0,0,8" />
                <StackPanel Orientation="Horizontal" Margin="0,0,0,16">
                    <RadioButton Content="Daily" IsChecked="{Binding IsDailySelected}" Margin="0,0,16,0"
                                 Foreground="{StaticResource TextBrush}" FontSize="13" />
                    <RadioButton Content="Weekly" Foreground="{StaticResource TextBrush}" FontSize="13" />
                </StackPanel>

                <!-- Target Duration -->
                <TextBlock Text="Target Duration" FontSize="13" FontWeight="SemiBold"
                           Foreground="{StaticResource TextBrush}" Margin="0,0,0,8" />
                <StackPanel Orientation="Horizontal">
                    <ComboBox ItemsSource="{Binding HourOptions}" SelectedItem="{Binding TargetHours}"
                              Width="80" Style="{StaticResource {x:Type ComboBox}}" />
                    <TextBlock Text=" hours " FontSize="13" VerticalAlignment="Center"
                               Foreground="{StaticResource TextSecondaryBrush}" />
                    <ComboBox ItemsSource="{Binding MinuteOptions}" SelectedItem="{Binding TargetMinutes}"
                              Width="80" Style="{StaticResource {x:Type ComboBox}}" />
                    <TextBlock Text=" minutes" FontSize="13" VerticalAlignment="Center"
                               Foreground="{StaticResource TextSecondaryBrush}" />
                </StackPanel>
            </StackPanel>

            <!-- Buttons -->
            <StackPanel Grid.Row="2" Orientation="Horizontal" HorizontalAlignment="Right" Margin="0,16,0,0">
                <Button Content="Cancel" Style="{StaticResource SecondaryButtonStyle}" Margin="0,0,8,0"
                        Click="OnCancel" />
                <Button Content="Set Goal" Style="{StaticResource PrimaryButtonStyle}"
                        Command="{Binding ConfirmCommand}" Click="OnConfirm" />
            </StackPanel>
        </Grid>
    </Border>
</Window>
