<Window x:Class="FocusGuard.App.Views.StartSessionDialog"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:converters="clr-namespace:FocusGuard.App.Converters"
        Title="Start Focus Session" Width="440" Height="480"
        WindowStartupLocation="CenterOwner" ResizeMode="NoResize"
        WindowStyle="None" AllowsTransparency="True" Background="Transparent">
    <Window.Resources>
        <converters:HexToColorConverter x:Key="HexToColorConverter" />
        <converters:BoolToVisibilityConverter x:Key="BoolToVisibilityConverter" />
        <converters:InverseBoolToVisibilityConverter x:Key="InverseBoolToVisibilityConverter" />
    </Window.Resources>

    <Border Background="{StaticResource BackgroundBrush}" CornerRadius="12"
            BorderBrush="{StaticResource BorderBrush}" BorderThickness="1">
        <Grid Margin="24">
            <Grid.RowDefinitions>
                <RowDefinition Height="Auto" />
                <RowDefinition Height="*" />
                <RowDefinition Height="Auto" />
            </Grid.RowDefinitions>

            <!-- Header -->
            <StackPanel Grid.Row="0">
                <StackPanel Orientation="Horizontal" Margin="0,0,0,16">
                    <Ellipse Width="16" Height="16"
                             Fill="{Binding ProfileColor, Converter={StaticResource HexToColorConverter}}"
                             Margin="0,0,10,0" VerticalAlignment="Center" />
                    <TextBlock Text="{Binding ProfileName}" Style="{StaticResource HeadingStyle}"
                               Margin="0" />
                </StackPanel>
            </StackPanel>

            <!-- Content -->
            <StackPanel Grid.Row="1">
                <!-- Duration presets (Pomodoro OFF) -->
                <StackPanel Visibility="{Binding EnablePomodoro, Converter={StaticResource InverseBoolToVisibilityConverter}}">
                    <TextBlock Text="Duration" Style="{StaticResource SubheadingStyle}" Margin="0,0,0,8" />
                    <WrapPanel Margin="0,0,0,8">
                        <Button Content="25m" Style="{StaticResource SecondaryButtonStyle}" Margin="0,0,8,8"
                                Command="{Binding SetDurationCommand}" CommandParameter="25" />
                        <Button Content="45m" Style="{StaticResource SecondaryButtonStyle}" Margin="0,0,8,8"
                                Command="{Binding SetDurationCommand}" CommandParameter="45" />
                        <Button Content="60m" Style="{StaticResource SecondaryButtonStyle}" Margin="0,0,8,8"
                                Command="{Binding SetDurationCommand}" CommandParameter="60" />
                        <Button Content="90m" Style="{StaticResource SecondaryButtonStyle}" Margin="0,0,8,8"
                                Command="{Binding SetDurationCommand}" CommandParameter="90" />
                        <Button Content="120m" Style="{StaticResource SecondaryButtonStyle}" Margin="0,0,8,8"
                                Command="{Binding SetDurationCommand}" CommandParameter="120" />
                    </WrapPanel>

                    <StackPanel Orientation="Horizontal" Margin="0,0,0,16">
                        <TextBlock Text="Custom:" Foreground="{StaticResource TextSecondaryBrush}"
                                   VerticalAlignment="Center" FontSize="13" Margin="0,0,8,0" />
                        <TextBox Style="{StaticResource DarkTextBoxStyle}" Width="70"
                                 Text="{Binding DurationMinutes, UpdateSourceTrigger=PropertyChanged}"
                                 VerticalAlignment="Center" />
                        <TextBlock Text="minutes" Foreground="{StaticResource TextSecondaryBrush}"
                                   VerticalAlignment="Center" FontSize="13" Margin="8,0,0,0" />
                    </StackPanel>
                </StackPanel>

                <!-- Cycle count presets (Pomodoro ON) -->
                <StackPanel Visibility="{Binding EnablePomodoro, Converter={StaticResource BoolToVisibilityConverter}}">
                    <TextBlock Text="Pomodoro Cycles" Style="{StaticResource SubheadingStyle}" Margin="0,0,0,8" />
                    <WrapPanel Margin="0,0,0,8">
                        <Button Content="2" Style="{StaticResource SecondaryButtonStyle}" Margin="0,0,8,8"
                                Width="48"
                                Command="{Binding SetCycleCountCommand}" CommandParameter="2" />
                        <Button Content="4" Style="{StaticResource SecondaryButtonStyle}" Margin="0,0,8,8"
                                Width="48"
                                Command="{Binding SetCycleCountCommand}" CommandParameter="4" />
                        <Button Content="6" Style="{StaticResource SecondaryButtonStyle}" Margin="0,0,8,8"
                                Width="48"
                                Command="{Binding SetCycleCountCommand}" CommandParameter="6" />
                        <Button Content="8" Style="{StaticResource SecondaryButtonStyle}" Margin="0,0,8,8"
                                Width="48"
                                Command="{Binding SetCycleCountCommand}" CommandParameter="8" />
                    </WrapPanel>

                    <StackPanel Orientation="Horizontal" Margin="0,0,0,8">
                        <TextBlock Text="Custom:" Foreground="{StaticResource TextSecondaryBrush}"
                                   VerticalAlignment="Center" FontSize="13" Margin="0,0,8,0" />
                        <TextBox Style="{StaticResource DarkTextBoxStyle}" Width="70"
                                 Text="{Binding PomodoroCycleCount, UpdateSourceTrigger=PropertyChanged}"
                                 VerticalAlignment="Center" />
                        <TextBlock Text="cycles" Foreground="{StaticResource TextSecondaryBrush}"
                                   VerticalAlignment="Center" FontSize="13" Margin="8,0,0,0" />
                    </StackPanel>

                    <TextBlock Text="{Binding PomodoroDurationDisplay}"
                               Foreground="{StaticResource TextSecondaryBrush}"
                               FontSize="12" Margin="0,0,0,16" />
                </StackPanel>

                <!-- Pomodoro Toggle -->
                <CheckBox IsChecked="{Binding EnablePomodoro}" Margin="0,0,0,16" Cursor="Hand">
                    <TextBlock Text="Enable Pomodoro Mode" Foreground="{StaticResource TextBrush}" FontSize="13" />
                </CheckBox>

                <!-- Password Difficulty -->
                <TextBlock Text="Password Difficulty" Style="{StaticResource SubheadingStyle}" Margin="0,0,0,8" />
                <ComboBox ItemsSource="{Binding AvailableDifficulties}"
                          SelectedItem="{Binding SelectedDifficulty}"
                          Width="200" HorizontalAlignment="Left"
                          Background="{StaticResource SurfaceLightBrush}"
                          Foreground="{StaticResource TextBrush}"
                          BorderBrush="{StaticResource BorderBrush}"
                          FontSize="13" Padding="10,8" />
            </StackPanel>

            <!-- Buttons -->
            <StackPanel Grid.Row="2" Orientation="Horizontal" HorizontalAlignment="Right" Margin="0,16,0,0">
                <Button Content="Cancel" Style="{StaticResource SecondaryButtonStyle}"
                        Margin="0,0,8,0" Width="90"
                        Command="{Binding CancelCommand}"
                        CommandParameter="{Binding RelativeSource={RelativeSource AncestorType=Window}}" />
                <Button Content="Start Session" Style="{StaticResource PrimaryButtonStyle}"
                        Width="120"
                        Command="{Binding ConfirmCommand}"
                        CommandParameter="{Binding RelativeSource={RelativeSource AncestorType=Window}}" />
            </StackPanel>
        </Grid>
    </Border>
</Window>
