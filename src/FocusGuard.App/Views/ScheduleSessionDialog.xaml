<Window x:Class="FocusGuard.App.Views.ScheduleSessionDialog"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        Title="Schedule Session" Width="480" Height="560"
        WindowStartupLocation="CenterOwner"
        WindowStyle="None" AllowsTransparency="True"
        Background="Transparent" ResizeMode="NoResize"
        MouseLeftButtonDown="Window_MouseLeftButtonDown">
    <Border Background="{StaticResource BackgroundBrush}" CornerRadius="12"
            BorderBrush="{StaticResource BorderBrush}" BorderThickness="1">
        <Grid Margin="24">
            <Grid.RowDefinitions>
                <RowDefinition Height="Auto" />
                <RowDefinition Height="*" />
                <RowDefinition Height="Auto" />
            </Grid.RowDefinitions>

            <!-- Header -->
            <TextBlock Grid.Row="0" Text="Schedule Focus Session"
                       FontSize="18" FontWeight="SemiBold"
                       Foreground="{StaticResource TextBrush}" Margin="0,0,0,16" />

            <!-- Form -->
            <ScrollViewer Grid.Row="1" VerticalScrollBarVisibility="Auto">
                <StackPanel>
                    <!-- Profile Selector -->
                    <TextBlock Text="Profile" Foreground="{StaticResource TextSecondaryBrush}" FontSize="12" Margin="0,0,0,4" />
                    <ComboBox ItemsSource="{Binding AvailableProfiles}"
                              SelectedItem="{Binding SelectedProfile}"
                              DisplayMemberPath="Name"
                              Background="{StaticResource SurfaceLightBrush}"
                              Foreground="{StaticResource TextBrush}"
                              Margin="0,0,0,12" />

                    <!-- Date -->
                    <TextBlock Text="Date" Foreground="{StaticResource TextSecondaryBrush}" FontSize="12" Margin="0,0,0,4" />
                    <DatePicker SelectedDate="{Binding SessionDate}"
                                Margin="0,0,0,12" />

                    <!-- Time Range -->
                    <TextBlock Text="Time Range" Foreground="{StaticResource TextSecondaryBrush}" FontSize="12" Margin="0,0,0,4" />
                    <StackPanel Orientation="Horizontal" Margin="0,0,0,4">
                        <ComboBox ItemsSource="{Binding AvailableHours}" SelectedItem="{Binding StartHour}" Width="60"
                                  Background="{StaticResource SurfaceLightBrush}" Foreground="{StaticResource TextBrush}" />
                        <TextBlock Text=":" Foreground="{StaticResource TextBrush}" VerticalAlignment="Center" Margin="4,0" />
                        <ComboBox ItemsSource="{Binding AvailableMinutes}" SelectedItem="{Binding StartMinute}" Width="60"
                                  Background="{StaticResource SurfaceLightBrush}" Foreground="{StaticResource TextBrush}" />
                        <TextBlock Text="  to  " Foreground="{StaticResource TextSecondaryBrush}" VerticalAlignment="Center" />
                        <ComboBox ItemsSource="{Binding AvailableHours}" SelectedItem="{Binding EndHour}" Width="60"
                                  Background="{StaticResource SurfaceLightBrush}" Foreground="{StaticResource TextBrush}" />
                        <TextBlock Text=":" Foreground="{StaticResource TextBrush}" VerticalAlignment="Center" Margin="4,0" />
                        <ComboBox ItemsSource="{Binding AvailableMinutes}" SelectedItem="{Binding EndMinute}" Width="60"
                                  Background="{StaticResource SurfaceLightBrush}" Foreground="{StaticResource TextBrush}" />
                    </StackPanel>
                    <TextBlock Text="{Binding DurationDisplay}" Foreground="{StaticResource TextSecondaryBrush}"
                               FontSize="12" Margin="0,0,0,12" />

                    <!-- Pomodoro -->
                    <CheckBox IsChecked="{Binding PomodoroEnabled}" Margin="0,0,0,12" Cursor="Hand">
                        <TextBlock Text="Enable Pomodoro Mode" Foreground="{StaticResource TextBrush}" />
                    </CheckBox>

                    <!-- Recurring -->
                    <CheckBox IsChecked="{Binding IsRecurring}" Margin="0,0,0,8" Cursor="Hand">
                        <TextBlock Text="Recurring" Foreground="{StaticResource TextBrush}" />
                    </CheckBox>

                    <!-- Recurrence Options -->
                    <StackPanel Visibility="{Binding IsRecurring, Converter={StaticResource BoolToVisibilityConverter}}"
                                Margin="20,0,0,0">
                        <TextBlock Text="Repeat" Foreground="{StaticResource TextSecondaryBrush}" FontSize="12" Margin="0,0,0,4" />
                        <ComboBox ItemsSource="{Binding AvailableRecurrenceTypes}"
                                  SelectedItem="{Binding SelectedRecurrenceType}" Width="180"
                                  Background="{StaticResource SurfaceLightBrush}" Foreground="{StaticResource TextBrush}"
                                  Margin="0,0,0,8" />

                        <!-- Custom Days (visible only when Custom) -->
                        <StackPanel Orientation="Horizontal" Margin="0,0,0,8">
                            <StackPanel.Style>
                                <Style TargetType="StackPanel">
                                    <Setter Property="Visibility" Value="Collapsed" />
                                    <Style.Triggers>
                                        <DataTrigger Binding="{Binding SelectedRecurrenceType}" Value="Custom">
                                            <Setter Property="Visibility" Value="Visible" />
                                        </DataTrigger>
                                    </Style.Triggers>
                                </Style>
                            </StackPanel.Style>
                            <CheckBox IsChecked="{Binding MondayChecked}" Content="Mon" Foreground="{StaticResource TextBrush}" Margin="0,0,8,0" />
                            <CheckBox IsChecked="{Binding TuesdayChecked}" Content="Tue" Foreground="{StaticResource TextBrush}" Margin="0,0,8,0" />
                            <CheckBox IsChecked="{Binding WednesdayChecked}" Content="Wed" Foreground="{StaticResource TextBrush}" Margin="0,0,8,0" />
                            <CheckBox IsChecked="{Binding ThursdayChecked}" Content="Thu" Foreground="{StaticResource TextBrush}" Margin="0,0,8,0" />
                            <CheckBox IsChecked="{Binding FridayChecked}" Content="Fri" Foreground="{StaticResource TextBrush}" Margin="0,0,8,0" />
                            <CheckBox IsChecked="{Binding SaturdayChecked}" Content="Sat" Foreground="{StaticResource TextBrush}" Margin="0,0,8,0" />
                            <CheckBox IsChecked="{Binding SundayChecked}" Content="Sun" Foreground="{StaticResource TextBrush}" />
                        </StackPanel>

                        <TextBlock Text="End Date (optional)" Foreground="{StaticResource TextSecondaryBrush}" FontSize="12" Margin="0,0,0,4" />
                        <DatePicker SelectedDate="{Binding RecurrenceEndDate}"
                                    Width="180" HorizontalAlignment="Left" />
                    </StackPanel>
                </StackPanel>
            </ScrollViewer>

            <!-- Buttons -->
            <StackPanel Grid.Row="2" Orientation="Horizontal" HorizontalAlignment="Right" Margin="0,16,0,0">
                <Button Content="Cancel" Style="{StaticResource SecondaryButtonStyle}"
                        Command="{Binding CancelCommand}" CommandParameter="{Binding RelativeSource={RelativeSource AncestorType=Window}}"
                        Margin="0,0,8,0" />
                <Button Content="Schedule" Style="{StaticResource PrimaryButtonStyle}"
                        Command="{Binding ConfirmCommand}" CommandParameter="{Binding RelativeSource={RelativeSource AncestorType=Window}}" />
            </StackPanel>
        </Grid>
    </Border>
</Window>
