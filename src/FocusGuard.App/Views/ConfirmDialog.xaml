<Window x:Class="FocusGuard.App.Views.ConfirmDialog"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        Title="Confirm"
        Width="420" SizeToContent="Height"
        WindowStyle="None" AllowsTransparency="True"
        WindowStartupLocation="CenterOwner" ResizeMode="NoResize"
        Background="Transparent"
        MouseLeftButtonDown="OnDragMove">
    <Border Background="{StaticResource BackgroundBrush}" CornerRadius="12"
            BorderBrush="{StaticResource BorderBrush}" BorderThickness="1">
        <Grid Margin="24">
            <Grid.RowDefinitions>
                <RowDefinition Height="Auto" />
                <RowDefinition Height="Auto" />
                <RowDefinition Height="Auto" />
            </Grid.RowDefinitions>

            <!-- Title -->
            <TextBlock x:Name="TitleText" Grid.Row="0"
                       FontSize="18" FontWeight="Bold"
                       Foreground="{StaticResource TextBrush}"
                       Margin="0,0,0,12" />

            <!-- Message -->
            <TextBlock x:Name="MessageText" Grid.Row="1"
                       FontSize="13" TextWrapping="Wrap"
                       Foreground="{StaticResource TextSecondaryBrush}"
                       Margin="0,0,0,24" />

            <!-- Buttons -->
            <StackPanel Grid.Row="2" Orientation="Horizontal" HorizontalAlignment="Right">
                <Button Content="No" Style="{StaticResource SecondaryButtonStyle}"
                        Width="80" Margin="0,0,8,0" Click="OnNo" />
                <Button Content="Yes" Style="{StaticResource PrimaryButtonStyle}"
                        Width="80" Click="OnYes" />
            </StackPanel>
        </Grid>
    </Border>
</Window>
