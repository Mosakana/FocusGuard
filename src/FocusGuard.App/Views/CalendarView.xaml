<UserControl x:Class="FocusGuard.App.Views.CalendarView"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:converters="clr-namespace:FocusGuard.App.Converters">
    <UserControl.Resources>
        <converters:HexToColorConverter x:Key="HexToColorConverter" />
    </UserControl.Resources>

    <Grid>
        <Grid.ColumnDefinitions>
            <ColumnDefinition Width="*" />
            <ColumnDefinition Width="280" />
        </Grid.ColumnDefinitions>

        <!-- Left: Monthly Grid -->
        <StackPanel Grid.Column="0" Margin="0,0,16,0">
            <TextBlock Text="Calendar" Style="{StaticResource HeadingStyle}" />

            <!-- Month Navigation -->
            <Border Style="{StaticResource CardStyle}" Padding="12">
                <Grid>
                    <Grid.ColumnDefinitions>
                        <ColumnDefinition Width="Auto" />
                        <ColumnDefinition Width="*" />
                        <ColumnDefinition Width="Auto" />
                        <ColumnDefinition Width="Auto" />
                    </Grid.ColumnDefinitions>
                    <Button Grid.Column="0" Content="&#x25C0;" Style="{StaticResource SecondaryButtonStyle}"
                            Command="{Binding PreviousMonthCommand}" Padding="8,4" />
                    <TextBlock Grid.Column="1" Text="{Binding MonthYearDisplay}"
                               FontSize="16" FontWeight="SemiBold"
                               Foreground="{StaticResource TextBrush}"
                               HorizontalAlignment="Center" VerticalAlignment="Center" />
                    <Button Grid.Column="2" Content="Today" Style="{StaticResource SecondaryButtonStyle}"
                            Command="{Binding GoToTodayCommand}" Padding="8,4" Margin="0,0,8,0" />
                    <Button Grid.Column="3" Content="&#x25B6;" Style="{StaticResource SecondaryButtonStyle}"
                            Command="{Binding NextMonthCommand}" Padding="8,4" />
                </Grid>
            </Border>

            <!-- Day-of-Week Headers -->
            <UniformGrid Rows="1" Columns="7" Margin="0,8,0,4">
                <TextBlock Text="Mon" HorizontalAlignment="Center" Foreground="{StaticResource TextSecondaryBrush}" FontSize="12" />
                <TextBlock Text="Tue" HorizontalAlignment="Center" Foreground="{StaticResource TextSecondaryBrush}" FontSize="12" />
                <TextBlock Text="Wed" HorizontalAlignment="Center" Foreground="{StaticResource TextSecondaryBrush}" FontSize="12" />
                <TextBlock Text="Thu" HorizontalAlignment="Center" Foreground="{StaticResource TextSecondaryBrush}" FontSize="12" />
                <TextBlock Text="Fri" HorizontalAlignment="Center" Foreground="{StaticResource TextSecondaryBrush}" FontSize="12" />
                <TextBlock Text="Sat" HorizontalAlignment="Center" Foreground="{StaticResource TextSecondaryBrush}" FontSize="12" />
                <TextBlock Text="Sun" HorizontalAlignment="Center" Foreground="{StaticResource TextSecondaryBrush}" FontSize="12" />
            </UniformGrid>

            <!-- 6x7 Calendar Grid -->
            <ItemsControl ItemsSource="{Binding Days}">
                <ItemsControl.ItemsPanel>
                    <ItemsPanelTemplate>
                        <UniformGrid Rows="6" Columns="7" />
                    </ItemsPanelTemplate>
                </ItemsControl.ItemsPanel>
                <ItemsControl.ItemTemplate>
                    <DataTemplate>
                        <Border Margin="1" Padding="4" MinHeight="64" CornerRadius="4" Cursor="Hand"
                                MouseLeftButtonDown="DayCell_MouseLeftButtonDown">
                            <Border.Style>
                                <Style TargetType="Border">
                                    <Setter Property="Background" Value="{StaticResource SurfaceBrush}" />
                                    <Style.Triggers>
                                        <DataTrigger Binding="{Binding IsCurrentMonth}" Value="False">
                                            <Setter Property="Opacity" Value="0.4" />
                                        </DataTrigger>
                                        <DataTrigger Binding="{Binding IsToday}" Value="True">
                                            <Setter Property="BorderBrush" Value="{StaticResource PrimaryBrush}" />
                                            <Setter Property="BorderThickness" Value="2" />
                                        </DataTrigger>
                                        <Trigger Property="IsMouseOver" Value="True">
                                            <Setter Property="Background" Value="#2E2E42" />
                                        </Trigger>
                                        <DataTrigger Binding="{Binding IsSelected}" Value="True">
                                            <Setter Property="Background" Value="{StaticResource SurfaceLightBrush}" />
                                        </DataTrigger>
                                    </Style.Triggers>
                                </Style>
                            </Border.Style>
                            <StackPanel>
                                <TextBlock Text="{Binding Date.Day}" FontSize="12" FontWeight="SemiBold"
                                           Foreground="{StaticResource TextBrush}" Margin="2,0,0,2" />
                                <!-- Session dots -->
                                <ItemsControl ItemsSource="{Binding TimeBlocks}">
                                    <ItemsControl.ItemTemplate>
                                        <DataTemplate>
                                            <Border Background="{Binding ProfileColor, Converter={StaticResource HexToColorConverter}}"
                                                    CornerRadius="2" Padding="2,1" Margin="0,0,0,1">
                                                <TextBlock Text="{Binding ProfileName}" FontSize="9"
                                                           Foreground="White" TextTrimming="CharacterEllipsis" />
                                            </Border>
                                        </DataTemplate>
                                    </ItemsControl.ItemTemplate>
                                </ItemsControl>
                            </StackPanel>
                        </Border>
                    </DataTemplate>
                </ItemsControl.ItemTemplate>
            </ItemsControl>
        </StackPanel>

        <!-- Right: Side Panel -->
        <Border Grid.Column="1" Style="{StaticResource CardStyle}">
            <DockPanel>
                <!-- Panel Header -->
                <StackPanel DockPanel.Dock="Top">
                    <TextBlock FontSize="15" FontWeight="SemiBold"
                               Foreground="{StaticResource TextBrush}" Margin="0,0,0,4">
                        <TextBlock.Text>
                            <Binding Path="SelectedDay.Date" StringFormat="{}{0:dddd, MMM d}" FallbackValue="Select a day" />
                        </TextBlock.Text>
                    </TextBlock>
                    <Button Content="+ New Session" Style="{StaticResource PrimaryButtonStyle}"
                            Command="{Binding CreateScheduledSessionCommand}"
                            HorizontalAlignment="Stretch" Margin="0,8,0,12" />
                </StackPanel>

                <!-- Session List for Selected Day -->
                <ScrollViewer VerticalScrollBarVisibility="Auto">
                    <ItemsControl ItemsSource="{Binding SelectedDayBlocks}">
                        <ItemsControl.ItemTemplate>
                            <DataTemplate>
                                <Border Background="{StaticResource SurfaceLightBrush}" CornerRadius="6"
                                        Padding="10" Margin="0,0,0,8">
                                    <Grid>
                                        <Grid.ColumnDefinitions>
                                            <ColumnDefinition Width="4" />
                                            <ColumnDefinition Width="*" />
                                            <ColumnDefinition Width="Auto" />
                                        </Grid.ColumnDefinitions>

                                        <!-- Color Bar -->
                                        <Border Grid.Column="0" CornerRadius="2"
                                                Background="{Binding ProfileColor, Converter={StaticResource HexToColorConverter}}" />

                                        <!-- Info -->
                                        <StackPanel Grid.Column="1" Margin="8,0,0,0">
                                            <TextBlock Text="{Binding ProfileName}" FontSize="13" FontWeight="SemiBold"
                                                       Foreground="{StaticResource TextBrush}" />
                                            <TextBlock Text="{Binding TimeRangeDisplay}" FontSize="11"
                                                       Foreground="{StaticResource TextSecondaryBrush}" Margin="0,2,0,0" />
                                            <StackPanel Orientation="Horizontal" Margin="0,2,0,0">
                                                <TextBlock FontSize="10" Foreground="{StaticResource TextSecondaryBrush}">
                                                    <Run Text="{Binding DurationMinutes, Mode=OneWay}" />
                                                    <Run Text=" min" />
                                                </TextBlock>
                                                <TextBlock Text=" | Pomodoro" FontSize="10"
                                                           Foreground="{StaticResource PrimaryBrush}"
                                                           Visibility="{Binding PomodoroEnabled, Converter={StaticResource BoolToVisibilityConverter}}"
                                                           Margin="6,0,0,0" />
                                                <TextBlock Text=" | Recurring" FontSize="10"
                                                           Foreground="{StaticResource TextSecondaryBrush}"
                                                           Visibility="{Binding IsRecurring, Converter={StaticResource BoolToVisibilityConverter}}"
                                                           Margin="6,0,0,0" />
                                            </StackPanel>
                                        </StackPanel>

                                        <!-- Delete -->
                                        <Button Grid.Column="2" Content="&#x2715;"
                                                Style="{StaticResource SecondaryButtonStyle}"
                                                Padding="6,2" FontSize="10" VerticalAlignment="Top"
                                                Command="{Binding DataContext.DeleteScheduledSessionCommand, RelativeSource={RelativeSource AncestorType=UserControl}}"
                                                CommandParameter="{Binding ScheduledSessionId}" />
                                    </Grid>
                                </Border>
                            </DataTemplate>
                        </ItemsControl.ItemTemplate>
                    </ItemsControl>
                </ScrollViewer>
            </DockPanel>
        </Border>
    </Grid>
</UserControl>
