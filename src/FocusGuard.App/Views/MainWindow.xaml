<Window x:Class="FocusGuard.App.Views.MainWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:shell="clr-namespace:System.Windows.Shell;assembly=PresentationFramework"
        Title="FocusGuard" Height="700" Width="1100"
        MinHeight="500" MinWidth="800"
        WindowStartupLocation="CenterScreen"
        WindowStyle="None"
        Background="{StaticResource BackgroundBrush}"
        Icon="/Resources/focusguard.ico">

    <WindowChrome.WindowChrome>
        <WindowChrome CaptionHeight="36"
                      ResizeBorderThickness="5"
                      GlassFrameThickness="0"
                      CornerRadius="0"
                      UseAeroCaptionButtons="False" />
    </WindowChrome.WindowChrome>

    <Grid>
        <Grid.RowDefinitions>
            <RowDefinition Height="36" />
            <RowDefinition Height="*" />
        </Grid.RowDefinitions>

        <!-- Custom Title Bar -->
        <Grid Grid.Row="0" Background="{StaticResource SurfaceBrush}">
            <Grid.ColumnDefinitions>
                <ColumnDefinition Width="*" />
                <ColumnDefinition Width="Auto" />
            </Grid.ColumnDefinitions>

            <!-- Left side: Icon + Title -->
            <StackPanel Grid.Column="0" Orientation="Horizontal" VerticalAlignment="Center" Margin="10,0,0,0">
                <Image Source="/Resources/focusguard.ico" Width="16" Height="16" Margin="0,0,8,0"
                       RenderOptions.BitmapScalingMode="HighQuality" />
                <TextBlock Text="FocusGuard" FontSize="12" FontWeight="SemiBold"
                           Foreground="{StaticResource TextSecondaryBrush}" VerticalAlignment="Center" />
            </StackPanel>

            <!-- Right side: Window buttons -->
            <StackPanel Grid.Column="1" Orientation="Horizontal">
                <!-- Minimize -->
                <Button x:Name="MinimizeButton" Style="{StaticResource TitleBarButtonStyle}"
                        shell:WindowChrome.IsHitTestVisibleInChrome="True"
                        Click="MinimizeButton_Click">
                    <Path Data="M 0,0 L 10,0" Stroke="{StaticResource TextSecondaryBrush}" StrokeThickness="1"
                          HorizontalAlignment="Center" VerticalAlignment="Center" Width="10" Height="1" />
                </Button>

                <!-- Maximize/Restore -->
                <Button x:Name="MaximizeButton" Style="{StaticResource TitleBarButtonStyle}"
                        shell:WindowChrome.IsHitTestVisibleInChrome="True"
                        Click="MaximizeButton_Click">
                    <Path x:Name="MaximizeIcon" Data="M 0,0 L 10,0 L 10,10 L 0,10 Z"
                          Stroke="{StaticResource TextSecondaryBrush}" StrokeThickness="1"
                          HorizontalAlignment="Center" VerticalAlignment="Center"
                          Width="10" Height="10" />
                </Button>

                <!-- Close -->
                <Button Style="{StaticResource TitleBarCloseButtonStyle}"
                        shell:WindowChrome.IsHitTestVisibleInChrome="True"
                        Click="CloseButton_Click" />
            </StackPanel>
        </Grid>

        <!-- Main Content -->
        <Grid Grid.Row="1">
            <Grid.ColumnDefinitions>
                <ColumnDefinition Width="220" />
                <ColumnDefinition Width="*" />
            </Grid.ColumnDefinitions>

            <!-- Sidebar -->
            <Border Grid.Column="0" Background="{StaticResource SurfaceBrush}"
                    BorderBrush="{StaticResource BorderBrush}" BorderThickness="0,0,1,0">
                <DockPanel>
                    <!-- App Title -->
                    <StackPanel DockPanel.Dock="Top" Margin="16,20,16,24">
                        <TextBlock Text="FocusGuard" FontSize="22" FontWeight="Bold"
                                   Foreground="{StaticResource PrimaryBrush}" />
                        <TextBlock Text="Stay focused, stay productive"
                                   Foreground="{StaticResource TextSecondaryBrush}"
                                   FontSize="11" Margin="0,4,0,0" />
                    </StackPanel>

                    <!-- Version at bottom -->
                    <TextBlock DockPanel.Dock="Bottom" Text="v1.0.0"
                               Foreground="{StaticResource TextSecondaryBrush}"
                               FontSize="10" Margin="16,0,0,12"
                               VerticalAlignment="Bottom" />

                    <!-- Navigation Buttons -->
                    <StackPanel Margin="8,0">
                        <Button Content="&#x1F3E0;  Dashboard"
                                Style="{StaticResource NavButtonStyle}"
                                Command="{Binding NavigateToDashboardCommand}" />
                        <Button Content="&#x1F4CB;  Profiles"
                                Style="{StaticResource NavButtonStyle}"
                                Command="{Binding NavigateToProfilesCommand}" />
                        <Button Content="&#x1F4C5;  Calendar"
                                Style="{StaticResource NavButtonStyle}"
                                Command="{Binding NavigateToCalendarCommand}" />
                        <Button Content="&#x1F4CA;  Statistics"
                                Style="{StaticResource NavButtonStyle}"
                                Command="{Binding NavigateToStatisticsCommand}" />
                        <Button Content="&#x2699;  Settings"
                                Style="{StaticResource NavButtonStyle}"
                                Command="{Binding NavigateToSettingsCommand}" />
                    </StackPanel>
                </DockPanel>
            </Border>

            <!-- Content Area -->
            <ContentControl Grid.Column="1" Content="{Binding CurrentView}" Margin="24,20" />
        </Grid>
    </Grid>
</Window>
