<Window x:Class="FocusGuard.App.Views.TimerOverlayWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:controls="clr-namespace:FocusGuard.App.Controls"
        Width="180" Height="180"
        WindowStyle="None"
        AllowsTransparency="True"
        Background="Transparent"
        Topmost="True"
        ShowInTaskbar="False"
        ShowActivated="False"
        ResizeMode="NoResize">
    <Border CornerRadius="90" Background="#CC1E1E2E" BorderBrush="#44FFFFFF" BorderThickness="1">
        <Grid>
            <!-- Progress Ring -->
            <controls:CircularProgressRing
                Width="160" Height="160"
                HorizontalAlignment="Center"
                VerticalAlignment="Center"
                Progress="{Binding TimerProgress}"
                StrokeThickness="5"
                ProgressColor="#4A90D9"
                TrackColor="#3A3A4E" />

            <!-- Timer content -->
            <StackPanel HorizontalAlignment="Center" VerticalAlignment="Center">
                <!-- Profile name -->
                <TextBlock Text="{Binding ProfileName}"
                           Foreground="#88ECEFF4"
                           FontSize="10"
                           HorizontalAlignment="Center"
                           TextTrimming="CharacterEllipsis"
                           MaxWidth="120" />

                <!-- Timer display -->
                <TextBlock Text="{Binding TimerDisplay}"
                           Foreground="#ECEFF4"
                           FontFamily="Consolas"
                           FontSize="24"
                           FontWeight="Bold"
                           HorizontalAlignment="Center" />

                <!-- Interval label -->
                <TextBlock Text="{Binding IntervalLabel}"
                           Foreground="#88ECEFF4"
                           FontSize="11"
                           HorizontalAlignment="Center" />

                <!-- Pomodoro count -->
                <TextBlock Text="{Binding PomodoroCountDisplay}"
                           Foreground="#664A90D9"
                           FontSize="10"
                           HorizontalAlignment="Center" />
            </StackPanel>
        </Grid>
    </Border>
</Window>
