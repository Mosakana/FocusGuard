<UserControl x:Class="FocusGuard.App.Views.ProfilesView"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:converters="clr-namespace:FocusGuard.App.Converters">
    <UserControl.Resources>
        <converters:HexToColorConverter x:Key="HexToColorConverter" />
        <converters:BoolToVisibilityConverter x:Key="BoolToVisibilityConverter" />
        <converters:InverseBoolConverter x:Key="InverseBoolConverter" />
    </UserControl.Resources>

    <Grid>
        <Grid.ColumnDefinitions>
            <ColumnDefinition Width="280" />
            <ColumnDefinition Width="*" />
        </Grid.ColumnDefinitions>

        <!-- Profile List (Left) -->
        <Border Grid.Column="0" Background="{StaticResource SurfaceBrush}" CornerRadius="10" Margin="0,0,12,0">
            <DockPanel>
                <!-- Header with actions -->
                <StackPanel DockPanel.Dock="Top" Margin="16,16,16,12">
                    <TextBlock Text="Profiles" Style="{StaticResource HeadingStyle}" Margin="0" />
                    <WrapPanel Margin="0,12,0,0">
                        <Button Content="+ New" Style="{StaticResource PrimaryButtonStyle}"
                                Command="{Binding CreateProfileCommand}" Margin="0,0,6,4" Padding="12,6" />
                        <Button Content="Import" Style="{StaticResource SecondaryButtonStyle}"
                                Command="{Binding ImportProfileCommand}" Margin="0,0,6,4" Padding="12,6" />
                    </WrapPanel>
                </StackPanel>

                <!-- Profile List -->
                <ListBox ItemsSource="{Binding Profiles}"
                         SelectedItem="{Binding SelectedProfile}"
                         Background="Transparent" BorderThickness="0"
                         ScrollViewer.HorizontalScrollBarVisibility="Disabled">
                    <ListBox.ItemContainerStyle>
                        <Style TargetType="ListBoxItem">
                            <Setter Property="Padding" Value="12,10" />
                            <Setter Property="Margin" Value="4,1" />
                            <Setter Property="Cursor" Value="Hand" />
                            <Setter Property="Template">
                                <Setter.Value>
                                    <ControlTemplate TargetType="ListBoxItem">
                                        <Border x:Name="border" Background="Transparent"
                                                CornerRadius="8" Padding="{TemplateBinding Padding}"
                                                Margin="{TemplateBinding Margin}">
                                            <ContentPresenter />
                                        </Border>
                                        <ControlTemplate.Triggers>
                                            <Trigger Property="IsMouseOver" Value="True">
                                                <Setter TargetName="border" Property="Background"
                                                        Value="{StaticResource SurfaceLightBrush}" />
                                            </Trigger>
                                            <Trigger Property="IsSelected" Value="True">
                                                <Setter TargetName="border" Property="Background"
                                                        Value="{StaticResource SurfaceLightBrush}" />
                                                <Setter TargetName="border" Property="BorderBrush"
                                                        Value="{StaticResource PrimaryBrush}" />
                                                <Setter TargetName="border" Property="BorderThickness"
                                                        Value="0,0,0,0" />
                                            </Trigger>
                                        </ControlTemplate.Triggers>
                                    </ControlTemplate>
                                </Setter.Value>
                            </Setter>
                        </Style>
                    </ListBox.ItemContainerStyle>
                    <ListBox.ItemTemplate>
                        <DataTemplate>
                            <StackPanel>
                                <StackPanel Orientation="Horizontal">
                                    <Ellipse Width="10" Height="10"
                                             Fill="{Binding Color, Converter={StaticResource HexToColorConverter}}"
                                             Margin="0,0,8,0" VerticalAlignment="Center" />
                                    <TextBlock Text="{Binding Name}" FontSize="13" FontWeight="SemiBold"
                                               Foreground="{StaticResource TextBrush}" />
                                </StackPanel>
                                <TextBlock Margin="18,4,0,0" FontSize="11"
                                           Foreground="{StaticResource TextSecondaryBrush}">
                                    <Run Text="{Binding WebsiteCount, Mode=OneWay}" />
                                    <Run Text=" sites, " />
                                    <Run Text="{Binding AppCount, Mode=OneWay}" />
                                    <Run Text=" apps" />
                                </TextBlock>
                            </StackPanel>
                        </DataTemplate>
                    </ListBox.ItemTemplate>
                </ListBox>
            </DockPanel>
        </Border>

        <!-- Profile Editor (Right) -->
        <ScrollViewer Grid.Column="1" VerticalScrollBarVisibility="Auto"
                      Visibility="{Binding IsEditorVisible, Converter={StaticResource BoolToVisibilityConverter}}">
            <StackPanel DataContext="{Binding Editor}" Margin="4,0">
                <!-- Header -->
                <DockPanel Margin="0,0,0,16">
                    <StackPanel DockPanel.Dock="Right" Orientation="Horizontal">
                        <Button Content="Duplicate" Style="{StaticResource SecondaryButtonStyle}"
                                Command="{Binding DataContext.DuplicateProfileCommand, RelativeSource={RelativeSource AncestorType=UserControl}}"
                                Margin="0,0,6,0" Padding="12,6" />
                        <Button Content="Export" Style="{StaticResource SecondaryButtonStyle}"
                                Command="{Binding DataContext.ExportProfileCommand, RelativeSource={RelativeSource AncestorType=UserControl}}"
                                Margin="0,0,6,0" Padding="12,6" />
                        <Button Content="Delete" Style="{StaticResource DangerButtonStyle}"
                                Command="{Binding DataContext.DeleteProfileCommand, RelativeSource={RelativeSource AncestorType=UserControl}}"
                                Padding="12,6" />
                    </StackPanel>
                    <TextBlock Text="Edit Profile" Style="{StaticResource HeadingStyle}" Margin="0"
                               VerticalAlignment="Center" />
                </DockPanel>

                <!-- Name -->
                <Border Style="{StaticResource CardStyle}">
                    <StackPanel>
                        <TextBlock Text="Profile Name" Style="{StaticResource SubheadingStyle}" Margin="0,0,0,8" />
                        <TextBox Text="{Binding Name, UpdateSourceTrigger=PropertyChanged}"
                                 Style="{StaticResource DarkTextBoxStyle}" />
                    </StackPanel>
                </Border>

                <!-- Color -->
                <Border Style="{StaticResource CardStyle}">
                    <StackPanel>
                        <TextBlock Text="Color" Style="{StaticResource SubheadingStyle}" Margin="0,0,0,8" />
                        <ItemsControl ItemsSource="{Binding ColorSwatches}">
                            <ItemsControl.ItemsPanel>
                                <ItemsPanelTemplate>
                                    <WrapPanel />
                                </ItemsPanelTemplate>
                            </ItemsControl.ItemsPanel>
                            <ItemsControl.ItemTemplate>
                                <DataTemplate>
                                    <Button Width="32" Height="32" Margin="0,0,8,8" Cursor="Hand"
                                            Command="{Binding DataContext.SelectColorCommand, RelativeSource={RelativeSource AncestorType=ItemsControl}}"
                                            CommandParameter="{Binding}">
                                        <Button.Template>
                                            <ControlTemplate TargetType="Button">
                                                <Border CornerRadius="6"
                                                        Background="{Binding Converter={StaticResource HexToColorConverter}}"
                                                        BorderThickness="2"
                                                        BorderBrush="Transparent">
                                                </Border>
                                            </ControlTemplate>
                                        </Button.Template>
                                    </Button>
                                </DataTemplate>
                            </ItemsControl.ItemTemplate>
                        </ItemsControl>
                    </StackPanel>
                </Border>

                <!-- Blocked Websites -->
                <Border Style="{StaticResource CardStyle}">
                    <StackPanel>
                        <DockPanel Margin="0,0,0,8">
                            <TextBlock Text="Blocked Websites" Style="{StaticResource SubheadingStyle}" VerticalAlignment="Center" />
                        </DockPanel>

                        <!-- Add website -->
                        <DockPanel Margin="0,0,0,8">
                            <Button DockPanel.Dock="Right" Content="Add" Style="{StaticResource PrimaryButtonStyle}"
                                    Command="{Binding AddWebsiteCommand}" Padding="12,6" Margin="8,0,0,0" />
                            <TextBox Text="{Binding NewWebsite, UpdateSourceTrigger=PropertyChanged}"
                                     Style="{StaticResource DarkTextBoxStyle}" />
                        </DockPanel>

                        <!-- Website list -->
                        <ItemsControl ItemsSource="{Binding BlockedWebsites}">
                            <ItemsControl.ItemTemplate>
                                <DataTemplate>
                                    <Border Background="{StaticResource SurfaceLightBrush}" CornerRadius="6"
                                            Padding="10,6" Margin="0,0,0,4">
                                        <DockPanel>
                                            <Button DockPanel.Dock="Right" Content="x"
                                                    Foreground="{StaticResource DangerBrush}"
                                                    Background="Transparent" BorderThickness="0"
                                                    Cursor="Hand" FontWeight="Bold"
                                                    Command="{Binding DataContext.RemoveWebsiteCommand, RelativeSource={RelativeSource AncestorType=ItemsControl}}"
                                                    CommandParameter="{Binding}" />
                                            <TextBlock Text="{Binding}" Foreground="{StaticResource TextBrush}"
                                                       FontSize="13" VerticalAlignment="Center" />
                                        </DockPanel>
                                    </Border>
                                </DataTemplate>
                            </ItemsControl.ItemTemplate>
                        </ItemsControl>

                        <!-- Test Website Blocking -->
                        <StackPanel Orientation="Horizontal" Margin="0,8,0,0">
                            <Button Content="Test Website Blocking" Style="{StaticResource PrimaryButtonStyle}"
                                    Command="{Binding TestWebsiteBlockingCommand}"
                                    IsEnabled="{Binding IsWebsiteBlockingActive, Converter={StaticResource InverseBoolConverter}}"
                                    Padding="12,6" Margin="0,0,6,0" />
                            <Button Content="Stop" Style="{StaticResource DangerButtonStyle}"
                                    Command="{Binding StopWebsiteBlockingCommand}"
                                    Visibility="{Binding IsWebsiteBlockingActive, Converter={StaticResource BoolToVisibilityConverter}}"
                                    Padding="12,6" />
                        </StackPanel>
                    </StackPanel>
                </Border>

                <!-- Blocked Applications -->
                <Border Style="{StaticResource CardStyle}">
                    <StackPanel>
                        <TextBlock Text="Blocked Applications" Style="{StaticResource SubheadingStyle}" Margin="0,0,0,8" />

                        <!-- Add application -->
                        <DockPanel Margin="0,0,0,8">
                            <Button DockPanel.Dock="Right" Content="Browse" Style="{StaticResource SecondaryButtonStyle}"
                                    Command="{Binding BrowseApplicationCommand}" Padding="12,6" Margin="8,0,0,0" />
                            <Button DockPanel.Dock="Right" Content="Add" Style="{StaticResource PrimaryButtonStyle}"
                                    Command="{Binding AddApplicationCommand}" Padding="12,6" Margin="8,0,0,0" />
                            <TextBox Text="{Binding NewApplication, UpdateSourceTrigger=PropertyChanged}"
                                     Style="{StaticResource DarkTextBoxStyle}" />
                        </DockPanel>

                        <!-- App list -->
                        <ItemsControl ItemsSource="{Binding BlockedApplications}">
                            <ItemsControl.ItemTemplate>
                                <DataTemplate>
                                    <Border Background="{StaticResource SurfaceLightBrush}" CornerRadius="6"
                                            Padding="10,6" Margin="0,0,0,4">
                                        <DockPanel>
                                            <Button DockPanel.Dock="Right" Content="x"
                                                    Foreground="{StaticResource DangerBrush}"
                                                    Background="Transparent" BorderThickness="0"
                                                    Cursor="Hand" FontWeight="Bold"
                                                    Command="{Binding DataContext.RemoveApplicationCommand, RelativeSource={RelativeSource AncestorType=ItemsControl}}"
                                                    CommandParameter="{Binding}" />
                                            <TextBlock Text="{Binding}" Foreground="{StaticResource TextBrush}"
                                                       FontSize="13" VerticalAlignment="Center" />
                                        </DockPanel>
                                    </Border>
                                </DataTemplate>
                            </ItemsControl.ItemTemplate>
                        </ItemsControl>

                        <!-- Test App Blocking -->
                        <StackPanel Orientation="Horizontal" Margin="0,8,0,0">
                            <Button Content="Test App Blocking" Style="{StaticResource PrimaryButtonStyle}"
                                    Command="{Binding TestAppBlockingCommand}"
                                    IsEnabled="{Binding IsAppBlockingActive, Converter={StaticResource InverseBoolConverter}}"
                                    Padding="12,6" Margin="0,0,6,0" />
                            <Button Content="Stop" Style="{StaticResource DangerButtonStyle}"
                                    Command="{Binding StopAppBlockingCommand}"
                                    Visibility="{Binding IsAppBlockingActive, Converter={StaticResource BoolToVisibilityConverter}}"
                                    Padding="12,6" />
                        </StackPanel>
                    </StackPanel>
                </Border>

                <!-- Save/Discard -->
                <StackPanel Orientation="Horizontal" Margin="0,4,0,20">
                    <Button Content="Save Changes" Style="{StaticResource PrimaryButtonStyle}"
                            Command="{Binding SaveCommand}" Padding="16,8" Margin="0,0,8,0"
                            IsEnabled="{Binding HasUnsavedChanges}" />
                    <Button Content="Discard" Style="{StaticResource SecondaryButtonStyle}"
                            Command="{Binding DiscardCommand}" Padding="16,8"
                            IsEnabled="{Binding HasUnsavedChanges}" />
                </StackPanel>
            </StackPanel>
        </ScrollViewer>

        <!-- Empty state when no profile selected -->
        <StackPanel Grid.Column="1" VerticalAlignment="Center" HorizontalAlignment="Center"
                    Visibility="{Binding IsEditorVisible, Converter={StaticResource BoolToVisibilityConverter}, ConverterParameter=Invert}">
            <!-- Note: we'll handle the inverted visibility by checking if editor is NOT visible -->
        </StackPanel>
    </Grid>
</UserControl>
